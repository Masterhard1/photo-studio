# Скопируй этот файл в .env и заполни перед первым запуском сервера.
# Пароли нужны только при самом первом запуске — после этого они хранятся
# в виде хэшей в data/admin-config.json и data/admin-config-backup.json,
# и .env больше не используется для входа.

# Пароль мамы (основной вход). Не короче 10 символов, не "1234567890" и т.п.
ADMIN_PASSWORD_PRIMARY=

# Пароль для резервного входа (David). Должен отличаться от основного.
ADMIN_PASSWORD_BACKUP=

# Порт обычного HTTP-сервера (или HTTP->HTTPS редиректа, если включён SSL ниже).
PORT=3000

# Опционально: если есть настоящий TLS-сертификат (например, от Let's Encrypt),
# укажи пути к файлам — сервер поднимет HTTPS на HTTPS_PORT и будет редиректить
# весь обычный HTTP-трафик на https. Если не заполнено — сервер работает по
# обычному HTTP (нормально для локальной разработки).
SSL_KEY_PATH=
SSL_CERT_PATH=
HTTPS_PORT=443

# Включить запись клиентов на сайте (форма записи + раздел в админке).
# По умолчанию выключено — сайт и админка работают как раньше.
BOOKING_ENABLED=false
